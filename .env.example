# Copy to .env and fill in (do not commit .env).
# OpenAI-compatible API used by LLM-PySC2 agents.

LLM_MODEL_NAME=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=YOUR-API-KEY

# StarCraft II install root (folder containing Versions/ and Maps/)
SC2PATH=C:\Program Files (x86)\StarCraft II

# Full-game experiment (experiment_full_game.py)
SC2_DIFFICULTY_LEVEL=3
MAX_EPISODES=1
SC2_AGENT2_RACE=protoss
SC2_MODE=ECSB
LLM_PYSC2_NORENDER=1
